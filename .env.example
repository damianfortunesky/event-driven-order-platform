# ----------------------------------------------------------------------------
# Compose project
# ----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=event-driven-order-platform

# ----------------------------------------------------------------------------
# Kafka (KRaft)
# ----------------------------------------------------------------------------
# Host port exposed for local clients (apps on your machine).
KAFKA_EXTERNAL_PORT=9092
# Static cluster id for local single-node KRaft (keep fixed across restarts).
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
# Default partitions used when creating topics from bootstrap script.
KAFKA_DEFAULT_PARTITIONS=3

# Useful app-side bootstrap value (host access).
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka UI
KAFKA_UI_PORT=8080

# ----------------------------------------------------------------------------
# Postgres databases (one per bounded context)
# ----------------------------------------------------------------------------
POSTGRES_ORDER_PORT=5432
POSTGRES_ORDER_DB=order_db
POSTGRES_ORDER_USER=order_user
POSTGRES_ORDER_PASSWORD=order_pass

POSTGRES_PAYMENT_PORT=5433
POSTGRES_PAYMENT_DB=payment_db
POSTGRES_PAYMENT_USER=payment_user
POSTGRES_PAYMENT_PASSWORD=payment_pass

POSTGRES_INVENTORY_PORT=5434
POSTGRES_INVENTORY_DB=inventory_db
POSTGRES_INVENTORY_USER=inventory_user
POSTGRES_INVENTORY_PASSWORD=inventory_pass

POSTGRES_NOTIFICATION_PORT=5435
POSTGRES_NOTIFICATION_DB=notification_db
POSTGRES_NOTIFICATION_USER=notification_user
POSTGRES_NOTIFICATION_PASSWORD=notification_pass

# JDBC samples for local development (host access)
ORDER_DB_URL=jdbc:postgresql://localhost:5432/order_db
ORDER_DB_USERNAME=order_user
ORDER_DB_PASSWORD=order_pass

PAYMENT_DB_URL=jdbc:postgresql://localhost:5433/payment_db
PAYMENT_DB_USERNAME=payment_user
PAYMENT_DB_PASSWORD=payment_pass

INVENTORY_DB_URL=jdbc:postgresql://localhost:5434/inventory_db
INVENTORY_DB_USERNAME=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass

NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5435/notification_db
NOTIFICATION_DB_USERNAME=notification_user
NOTIFICATION_DB_PASSWORD=notification_pass

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
